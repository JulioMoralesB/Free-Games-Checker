# =============================================================================
# Free Games Notifier Environment Variables
# Copy this file to .env and fill in your actual values
# =============================================================================

# REQUIRED: Discord Webhook URL
# Get this from: Discord Server → Server Settings → Integrations → Webhooks
# Example: https://discordapp.com/api/webhooks/123456789/abcdefghijklmnopqrst
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_TOKEN

# Optional: Epic Games API URL (defaults to official API if not provided)
# Leave commented for default behavior
# EPIC_GAMES_API_URL=https://store-site-backend-static.ak.epicgames.com/freeGamesPromotions

# Optional: Health Check Monitoring (Healthchecks.io, UptimeKuma, etc)
# Set to your monitoring service ping URL to get alerts when notifier stops running
# HEALTHCHECK_URL=https://healthchecks.io/ping/YOUR_UUID_HERE

# Optional: Enable health check pings (true/false)
# Only enable if you've set HEALTHCHECK_URL
ENABLE_HEALTHCHECK=false

# Optional: PostgreSQL Database Configuration
# Leave all DB_* variables commented to use file-based JSON storage (default)
# If you want to use PostgreSQL, uncomment and fill in these values:

# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=free_games
# DB_USER=postgres
# DB_PASSWORD=your_secure_password

# Optional: Timezone for date display in Discord notifications
# Uses IANA timezone names. Defaults to America/Mexico_City.
# Examples: America/New_York, Europe/London, Asia/Tokyo, UTC
# TIMEZONE=America/Mexico_City

# Optional: Locale for date formatting (month names, etc.)
# The locale must be available in the system / Docker image.
# Leave empty to use the system default locale.
# Defaults to es_ES.UTF-8. Examples: en_US.UTF-8, de_DE.UTF-8, fr_FR.UTF-8
# LOCALE=es_ES.UTF-8

# Optional: Epic Games region used in store links
# Defaults to es-MX. Use your regional code to get localized store pages.
# Examples: en-US, de-DE, fr-FR, pt-BR
# EPIC_GAMES_REGION=es-MX

# Optional: Daily schedule time (HH:MM) at which free games are checked
# Interpreted in the timezone set by TIMEZONE above (defaults to America/Mexico_City).
# Defaults to 12:00
# SCHEDULE_TIME=12:00

# Optional: Health check ping interval in minutes
# Defaults to 1 minute
# HEALTHCHECK_INTERVAL=1

# Optional: strftime format string for the promotion end date shown in Discord
# Supported codes:
#   %d  - Day of the month (01-31)
#   %B  - Full month name (e.g. January, enero) — affected by LOCALE
#   %Y  - 4-digit year (e.g. 2025)
#   %I  - Hour in 12-hour format (01-12)
#   %H  - Hour in 24-hour format (00-23)
#   %M  - Minutes (00-59)
#   %p  - AM/PM locale string — include this when using %I (12-hour clock)
# Default is Spanish-style. Change to match your locale:
#   English example: "%B %d, %Y at %I:%M %p"  → January 31, 2025 at 03:00 PM
#   Spanish default: "%d de %B de %Y a las %I:%M %p"  → 31 de enero de 2025 a las 03:00 PM
#   24-hour example: "%d/%m/%Y %H:%M"  → 31/01/2025 15:00  (omit %p for 24-hour formats)
# DATE_FORMAT=%d de %B de %Y a las %I:%M %p

# Optional: API key for protecting mutating REST API endpoints (POST requests)
# If not set, no authentication is required.
# API_KEY=your_secret_api_key_here

# Optional: Host and port for the REST API server
# Defaults to 0.0.0.0:8000. Use 127.0.0.1 for local-only access.
# API_HOST=0.0.0.0
# API_PORT=8000

# =============================================================================
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and add your Discord webhook URL (minimum required)
# 3. (Optional) Add database credentials if using PostgreSQL
# 4. (Optional) Add health check URL if monitoring uptime
# 5. (Optional) Set TIMEZONE, LOCALE, EPIC_GAMES_REGION to match your region
# 6. (Optional) Set API_KEY to protect mutating API endpoints
# =============================================================================
