# Test environment configuration for GitHub Actions
# All optional env variables are configured with values other than defaults; DB and external webhooks are disabled

# Timezone for date display in notifications
TIMEZONE=Europe/London

# Locale for date formatting
LOCALE=fr_FR.UTF-8

# Epic Games API URL (using default, but can be overridden if needed)
EPIC_GAMES_API_URL=https://store-site-backend-static.ak.epicgames.com/freeGamesPromotions

# Epic Games region used in store links
EPIC_GAMES_REGION=de-DE

# Daily schedule time in HH:MM format
SCHEDULE_TIME=09:30

# strftime format string for date display in notifications
DATE_FORMAT=%B %d, %Y at %I:%M %p Test

# Volume paths for bind mounts
DATA_PATH=/tmp/free-games-test-data
LOGS_PATH=/tmp/free-games-test-logs

# REST API configuration
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=test-api-key-for-ci

# Optional: Discord webhook (disabled for CI)
# DISCORD_WEBHOOK_URL=

# Optional: Healthcheck monitor (disabled for CI)
# HEALTHCHECK_URL=
# ENABLE_HEALTHCHECK=false

# Optional: Health check interval in minutes (disabled for CI)
# HEALTHCHECK_INTERVAL=1

# Database configuration (disabled for CI - no DB in GitHub Actions)
# DB_HOST=
# DB_PORT=5432
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
